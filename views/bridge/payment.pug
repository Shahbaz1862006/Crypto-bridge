extends _layout

block bridgeContent
  div(class="w-full pt-0 pb-8")
    div(class="w-full px-6 lg:px-12 2xl:px-16")
      //- Method-select view
      div(data-payment-select, class="w-full max-w-3xl mx-auto px-4 sm:px-6")
        h1(class="text-2xl font-semibold text-[var(--text)] mb-4") Deposit & Payment
        div(class="space-y-4")
          div(class="w-full p-4 rounded-xl bg-[var(--surface)] border border-[var(--border)] flex items-center justify-between gap-4 shadow-[var(--shadow)]")
            span(class="text-2xl font-bold text-[var(--text)]") 60 USDT
            span(class="text-2xl font-bold text-[var(--text)]") ≈ ₹4,980 INR
          div(class="flex flex-col gap-3")
            button(type="button", data-pay-upi,
              class="w-full flex items-center gap-4 p-4 rounded-xl bg-[var(--surface)] border-2 border-[var(--border)] hover:border-[var(--green)] transition-colors text-left shadow-[var(--shadow)]")
              div(class="w-12 h-12 rounded-lg bg-[var(--green)]/15 flex items-center justify-center overflow-hidden")
                img(src="/assets/upi-logo.png", alt="UPI", class="h-7 w-auto object-contain")
              div
                h3(class="font-semibold text-[var(--text)]") Buy via UPI
                p(class="text-sm text-[var(--muted)]") Instant payment via UPI app
            button(type="button", data-pay-bank,
              class="w-full flex items-center gap-4 p-4 rounded-xl bg-[var(--surface)] border-2 border-[var(--border)] hover:border-[var(--green)] transition-colors text-left shadow-[var(--shadow)]")
              div(class="w-12 h-12 rounded-lg bg-[var(--green)]/15 flex items-center justify-center overflow-hidden")
                img(src="/assets/imps-logo.png", alt="IMPS", class="h-7 w-auto object-contain")
              div
                h3(class="font-semibold text-[var(--text)]") Buy via IMPS / RTGS / NEFT
                p(class="text-sm text-[var(--muted)]") Select beneficiary, then pay

      //- UPI view
      div(data-payment-upi, class="hidden")
        h1(class="text-2xl font-semibold text-[var(--text)] mb-4") Deposit & Payment
        div(class="grid grid-cols-1 lg:grid-cols-[1.6fr_1fr] gap-6 lg:gap-8 items-start w-full")
          div(class="order-1 w-full flex items-center justify-between rounded-xl border border-[var(--border)] bg-[var(--surface)] px-6 py-4 shadow-[var(--shadow)] lg:col-span-1 lg:col-start-1 lg:row-start-1")
            span(class="text-2xl font-semibold text-[var(--text)]") 60 USDT
            span(class="text-2xl font-semibold text-[var(--text)]") ≈ ₹4,980 INR
          div(class="order-2 w-full rounded-xl border border-[var(--border)] bg-[var(--surface)] p-6 shadow-[var(--shadow)] lg:col-span-1 lg:col-start-1 lg:row-start-2")
            h3(class="text-[var(--text)] font-medium mb-2") Beneficiary Details
            div(class="space-y-1.5")
              div(class="flex items-center gap-2 flex-wrap")
                span(class="text-[var(--muted)] text-sm") Beneficiary Name:
                span(class="text-[var(--text)]") Rapido Gate Collections
              div(class="flex items-center gap-2 flex-wrap")
                span(class="text-[var(--muted)] text-sm") Bank Name:
                span(class="text-[var(--text)]") HDFC Bank
              div(class="flex items-center gap-2 flex-wrap")
                span(class="text-[var(--muted)] text-sm") UPI ID:
                span(class="text-[var(--text)] font-mono") rapidogate@hdfc
                button(type="button", data-copy="rapidogate@hdfc", aria-label="Copy",
                  class="inline-flex items-center gap-1.5 text-[var(--muted)] hover:text-[var(--green)] transition-colors")
                  svg(class="w-4 h-4", fill="none", stroke="currentColor", viewBox="0 0 24 24")
                    path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z")
          div(class="order-3 lg:order-3 lg:col-span-1 lg:col-start-2 lg:row-span-3 lg:row-start-1 lg:sticky lg:top-6 lg:self-start w-full")
            div(class="w-full rounded-xl border border-[var(--border)] bg-[var(--surface)] p-6 flex flex-col shadow-[var(--shadow)]")
              p(class="text-[var(--text)] font-medium mb-1") Scan to pay
              p(class="text-[var(--muted)] text-sm mb-4") Amount: ₹4,980
              div(class="w-full rounded-lg border border-[var(--border)] bg-white p-4 flex items-center justify-center")
                div(data-upi-qr, class="w-[320px] h-[320px] flex items-center justify-center mx-auto shrink-0")
              div(class="mt-4 flex items-center justify-center gap-2 flex-wrap")
                span(class="text-[var(--muted)] text-sm") UPI ID:
                span(class="text-[var(--green)] font-mono text-sm") rapidogate@hdfc
                button(type="button", data-copy="rapidogate@hdfc", aria-label="Copy",
                  class="inline-flex items-center gap-1.5 text-[var(--muted)] hover:text-[var(--green)] transition-colors")
                  svg(class="w-4 h-4", fill="none", stroke="currentColor", viewBox="0 0 24 24")
                    path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z")
          div(class="order-4 w-full space-y-4 min-w-0 lg:col-span-1 lg:col-start-1 lg:row-start-3")
            div(class="w-full")
              label(for="utr-input", class="block text-[var(--text)] mb-2") Enter UTR / TxID
              input(id="utr-input", type="text", placeholder="e.g., 1234567890ABC", data-utr-input,
                class="w-full min-h-[44px] px-4 rounded-xl bg-white border text-[var(--text)] placeholder-[var(--muted)] focus:ring-2 focus:outline-none font-mono uppercase border-[var(--border)] focus:border-[var(--green)] focus:ring-[var(--focus)]")
              p(data-utr-error, class="hidden mt-1 text-sm text-red-500")
            button(type="button", data-utr-confirm, disabled,
              class="w-full rounded-xl py-4 text-lg font-semibold bg-[var(--green)] text-white hover:bg-[var(--green-hover)] disabled:opacity-50 disabled:cursor-not-allowed transition-colors") I have paid
          div(class="order-5 w-full lg:col-span-1 lg:col-start-1 lg:row-start-4")
            button(type="button", data-change-method,
              class="block w-full text-center text-[var(--green)] text-sm hover:underline mt-2") Change method

block scripts
  //- QR code library (pure-JS qrcode generator) for UPI QR rendering
  script(src="https://cdn.jsdelivr.net/npm/qrcode@1.5.4/build/qrcode.min.js")
