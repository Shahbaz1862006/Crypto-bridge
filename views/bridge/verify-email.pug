extends _layout

block bridgeContent
  div(class="w-full pt-0 pb-8")
    div(class="mx-auto w-full max-w-2xl px-4 sm:px-6")
      h1(class="mt-2 mb-6 text-2xl font-semibold text-[var(--text)]") Verify Yourself
      form(data-verify-email-form, novalidate, class="w-full space-y-4")
        div
          label(for="verify-email-input", class="block text-[var(--text)] mb-2") Enter Email
          input(
            id="verify-email-input",
            name="email",
            type="email",
            inputmode="email",
            autocomplete="email",
            placeholder="name@example.com",
            data-email-input,
            class="w-full min-h-[44px] px-4 rounded-xl bg-white border text-[var(--text)] placeholder-[var(--muted)] focus:outline-none focus:ring-2 border-[var(--border)] focus:border-[var(--green)] focus:ring-[var(--focus)]"
          )
          p(data-email-error, role="alert",
            class="hidden mt-2 text-sm text-red-500") Invalid Email
        div(class="flex flex-col items-center gap-3 pt-2")
          button(type="submit",
            class="min-h-[44px] w-full sm:max-w-md sm:px-8 rounded-xl bg-[var(--green)] text-white font-semibold hover:bg-[var(--green-hover)] transition-colors") Continue
          button(type="button", data-verify-email-cancel,
            class="min-h-[44px] w-full sm:max-w-md sm:px-8 rounded-xl border border-[var(--border)] text-[var(--muted)] hover:bg-gray-100 transition-colors") Cancel
