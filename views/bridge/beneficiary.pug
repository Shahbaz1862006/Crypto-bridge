extends _layout

block bridgeContent
  div(class="w-full pt-0 pb-8")
    div(class="w-full px-6 lg:px-12 2xl:px-16")
      h1(class="text-2xl font-semibold text-[var(--text)] mb-2") Payment
      p(class="text-[var(--muted)] mb-6") Transfer funds to the beneficiary below. Then select a cooling period.
      div(class="grid grid-cols-1 lg:grid-cols-12 gap-6")
        div(class="lg:col-span-7 flex flex-col gap-4")
          div(class="p-4 rounded-xl bg-[var(--surface)] border border-[var(--border)] flex items-center justify-between gap-4 shadow-[var(--shadow)]")
            span(class="text-2xl font-bold text-[var(--text)]", data-ben-usdt)= mock.bridge.usdt.display
            span(class="text-2xl font-bold text-[var(--text)]", data-ben-inr)= mock.bridge.inr.displayWithCurrency
          div(class="p-4 rounded-xl border border-[var(--border)] bg-[var(--surface)] cursor-default shadow-[var(--shadow)]")
            h3(class="text-[var(--text)] font-medium mb-2") Beneficiary Details
            div(class="space-y-1.5")
              div(class="flex items-center gap-2 flex-wrap")
                span(class="text-[var(--muted)] text-sm") Beneficiary Name:
                span(class="text-[var(--text)]")= mock.bridge.bankBeneficiary.name
              div(class="flex items-center gap-2 flex-wrap")
                span(class="text-[var(--muted)] text-sm") Bank Name:
                span(class="text-[var(--text)]")= mock.bridge.bankBeneficiary.bankName
              div(class="flex items-center gap-2 flex-wrap")
                span(class="text-[var(--muted)] text-sm") Account Number:
                span(class="text-[var(--text)] font-mono")= mock.bridge.bankBeneficiary.accountNumber
                button(type="button", data-copy=mock.bridge.bankBeneficiary.accountNumber, aria-label="Copy",
                  class="inline-flex items-center gap-1.5 text-[var(--muted)] hover:text-[var(--green)] transition-colors")
                  svg(class="w-4 h-4", fill="none", stroke="currentColor", viewBox="0 0 24 24")
                    path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z")
              div(class="flex items-center gap-2 flex-wrap")
                span(class="text-[var(--muted)] text-sm") IFSC:
                span(class="text-[var(--text)] font-mono")= mock.bridge.bankBeneficiary.ifsc
                button(type="button", data-copy=mock.bridge.bankBeneficiary.ifsc, aria-label="Copy",
                  class="inline-flex items-center gap-1.5 text-[var(--muted)] hover:text-[var(--green)] transition-colors")
                  svg(class="w-4 h-4", fill="none", stroke="currentColor", viewBox="0 0 24 24")
                    path(stroke-linecap="round", stroke-linejoin="round", stroke-width="2", d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z")
          div(data-brn-wrap, class="hidden w-full rounded-xl border border-[var(--border)] bg-[var(--surface)] p-6 flex flex-col gap-4 shadow-[var(--shadow)]")
            div(class="flex flex-col gap-2")
              div
                label(for="brn-input-inline", class="block text-[var(--text)] mb-2", data-brn-label) Enter BRN
                input(id="brn-input-inline", type="text", data-brn-input,
                  class="w-full min-h-[44px] px-4 rounded-xl bg-white border text-[var(--text)] placeholder-[var(--muted)] focus:ring-2 focus:outline-none font-mono uppercase border-[var(--border)] focus:border-[var(--green)] focus:ring-[var(--focus)]",
                  placeholder="E.G., BRN123456789")
                p(data-brn-error, class="hidden mt-1 text-sm text-red-500")
              button(type="button", data-brn-confirm, disabled,
                class="min-h-[44px] w-full rounded-xl bg-[var(--green)] text-white font-semibold hover:bg-[var(--green-hover)] disabled:opacity-50 disabled:cursor-not-allowed transition-colors") I have paid
            button(type="button", data-change-method,
              class="block w-full text-center text-[var(--green)] text-sm hover:underline") Change method
        div(class="lg:col-span-5 lg:sticky lg:top-6 lg:self-start flex flex-col gap-4")
          div(class="p-4 rounded-xl border border-[var(--border)] bg-[var(--surface)] flex flex-col shadow-[var(--shadow)]")
            label(for="cooling-select", class="block text-[var(--text)] font-medium mb-2") Cooling period
            select(id="cooling-select", data-cooling-select,
              class="w-full min-h-[44px] px-4 py-3 rounded-xl bg-white border border-[var(--border)] text-[var(--text)] focus:border-[var(--green)] focus:ring-2 focus:ring-[var(--focus)] focus:outline-none")
              option(value="") Select cooling period
              option(value="none") None
              option(value="30m") 30 mins
              option(value="4h") 4 hrs
              option(value="6h") 6 hrs
              option(value="24h") 24 hrs
              option(value="48h") 48 hrs
          button(type="button", data-ben-continue, disabled,
            class="min-h-[44px] w-full rounded-xl bg-[var(--green)] text-white font-semibold hover:bg-[var(--green-hover)] disabled:opacity-50 disabled:cursor-not-allowed transition-colors") Continue
