extends _layout

block bridgeContent
  div(class="w-full pt-0 pb-8")
    div(class="mx-auto w-full max-w-3xl px-4 sm:px-6 space-y-4")
      h1(class="text-2xl font-semibold text-[var(--text)]") Payment Verification
      div(class="w-full p-4 rounded-xl bg-[var(--surface)] border border-[var(--border)] shadow-[var(--shadow)]")
        div(class="grid grid-cols-[minmax(0,6rem)_1fr] gap-x-4 gap-y-3 text-sm")
          span(class="text-[var(--muted)]") USDT
          span(class="text-[var(--text)] font-medium", data-verify-usdt) 0 USDT
          span(class="text-[var(--muted)]") INR
          span(class="text-[var(--text)] font-medium", data-verify-inr) ₹0
          div(data-verify-ben-wrap, class="contents hidden")
            span(class="text-[var(--muted)]") Beneficiary
            span(class="text-[var(--text)] font-medium truncate", data-verify-ben-name)
        span(data-verify-cooling-badge, class="hidden inline-block mt-3 px-2 py-0.5 rounded bg-[var(--green)]/15 text-[var(--green)] text-xs") Cooling completed
      form(data-verify-form, class="w-full space-y-4")
        div
          label(for="ref-input", class="block text-[var(--text)] mb-2", data-verify-label) Enter Reference
          input(id="ref-input", type="text", data-verify-input, autocomplete="off",
            placeholder="Enter",
            class="w-full min-h-[44px] px-4 rounded-xl bg-white border border-[var(--border)] text-[var(--text)] placeholder-[var(--muted)] focus:border-[var(--green)] focus:ring-2 focus:ring-[var(--focus)] focus:outline-none uppercase")
          p(data-verify-error, class="hidden mt-2 text-sm text-red-500")
        button(type="submit", data-verify-submit, disabled,
          class="w-full min-h-[44px] rounded-xl bg-[var(--green)] text-white font-semibold disabled:opacity-50 disabled:cursor-not-allowed hover:bg-[var(--green-hover)]") Confirm
        button(type="button", data-verify-retry,
          class="hidden w-full min-h-[44px] rounded-xl border border-[var(--border)] text-[var(--muted)] hover:bg-gray-100") Retry
  //- Inline verifying overlay
  div(data-verify-processing, class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-[rgba(17,24,39,0.35)] backdrop-blur-sm")
    div(class="w-full max-w-sm rounded-xl bg-[var(--surface)] border border-[var(--border)] p-6 flex flex-col items-center gap-4 shadow-[var(--shadow)]")
      div(class="w-10 h-10 border-2 border-[var(--green)] border-t-transparent rounded-full animate-spin")
      p(class="text-[var(--text)] font-medium") Wait, payment processing…
