extends _layout

block bridgeContent
  div(class="w-full pt-0 pb-8")
    div(class="mx-auto w-full max-w-2xl px-4 sm:px-6")
      h1(class="mt-2 mb-4 text-2xl font-semibold text-gray-900") Buy Crypto
      p(class="mb-8 text-[var(--muted)] leading-relaxed")
        | Your deposit will be processed via Fastpikeswop. Fastpikeswop will convert your payment into USDT. Then you can send it to the merchant or withdraw to a personal wallet.
      div(class="flex flex-col items-center gap-3")
        button(type="button", data-explain-continue,
          class="min-h-[44px] w-full sm:max-w-md sm:px-8 rounded-xl bg-[var(--green)] text-white font-semibold hover:bg-[var(--green-hover)] transition-colors") Continue
        button(type="button", data-explain-cancel,
          class="min-h-[44px] w-full sm:max-w-md sm:px-8 rounded-xl border border-[var(--border)] text-[var(--muted)] hover:bg-gray-100 transition-colors") Cancel
