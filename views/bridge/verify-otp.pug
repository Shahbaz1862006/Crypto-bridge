extends _layout

block bridgeContent
  div(class="w-full pt-0 pb-8")
    div(class="mx-auto w-full max-w-2xl px-4 sm:px-6")
      h1(class="mt-2 mb-4 text-2xl font-semibold text-[var(--text)]") Verification
      p(class="mb-6 text-[var(--muted)] leading-relaxed")
        | Enter 6-digit verification code sent on 
        span(data-otp-email, class="text-[var(--text)] font-medium") &nbsp;
        | .
      form(data-verify-otp-form, novalidate, class="w-full space-y-4")
        div
          label(for="verify-otp-input", class="block text-[var(--text)] mb-2") Enter Code
          input(
            id="verify-otp-input",
            name="code",
            type="text",
            inputmode="numeric",
            autocomplete="one-time-code",
            maxlength="6",
            placeholder="••••••",
            data-otp-input,
            class="w-full min-h-[44px] px-4 rounded-xl bg-white border text-[var(--text)] placeholder-[var(--muted)] tracking-[0.3em] font-medium focus:outline-none focus:ring-2 border-[var(--border)] focus:border-[var(--green)] focus:ring-[var(--focus)]"
          )
          div(class="mt-2 flex flex-wrap items-center gap-2 text-sm")
            span(data-otp-error, class="hidden text-red-500", role="alert")
            span(data-otp-help, class="text-[var(--muted)]")
              | Didn’t receive code? 
              span(data-otp-countdown) Resend after 50s
              button(type="button", data-otp-resend, class="hidden text-[var(--green)] font-medium hover:underline") Resend
        div(class="flex flex-col items-center gap-3 pt-2")
          button(type="submit", data-otp-submit, disabled,
            class="min-h-[44px] w-full sm:max-w-md sm:px-8 rounded-xl bg-[var(--green)] text-white font-semibold hover:bg-[var(--green-hover)] transition-colors disabled:opacity-50 disabled:cursor-not-allowed") Submit
