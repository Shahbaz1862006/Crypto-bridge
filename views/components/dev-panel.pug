button(type="button", data-devpanel-toggle, aria-label="DEV", title="Dev Panel",
  class="fixed bottom-4 right-4 z-[9999] w-12 h-12 rounded-full bg-[var(--surface)] border border-[var(--border)] text-[var(--muted)] text-xs font-mono flex items-center justify-center hover:bg-gray-100 hover:text-[var(--text)] transition-colors shadow-[var(--shadow)]") DEV

div(data-devpanel,
    class="hidden fixed bottom-20 right-4 z-[9999] w-80 max-h-[70vh] overflow-y-auto rounded-xl bg-[var(--surface)] border border-[var(--border)] p-4 shadow-[var(--shadow)]")
  h3(class="text-sm font-semibold text-[var(--text)] mb-3") Dev Panel
  div(class="space-y-3 text-sm")
    div
      label(class="block text-[var(--muted)] mb-1") Exchange Rate (INR/USDT)
      input(type="number", step="0.1", placeholder="83", data-dev-rate,
        class="w-full px-2 py-1.5 rounded bg-white border border-[var(--border)] text-[var(--text)] text-xs")
    div(data-dev-ben-cooling, class="hidden")
      label(class="block text-[var(--muted)] mb-1") Beneficiary hasCooling
      div(class="flex gap-2")
        button(type="button", data-dev-ben-cooling-true, class="px-2 py-1 rounded text-xs bg-gray-200 text-[var(--muted)]") true
        button(type="button", data-dev-ben-cooling-false, class="px-2 py-1 rounded text-xs bg-gray-200 text-[var(--muted)]") false
    div
      label(class="block text-[var(--muted)] mb-1") Add mock tx
      div(class="flex flex-wrap gap-1")
        button(type="button", data-dev-add="ok", class="px-2 py-1 rounded bg-green-600/80 text-green-100 text-xs") + SUCCESSFUL
        button(type="button", data-dev-add="fail", class="px-2 py-1 rounded bg-red-600/80 text-red-100 text-xs") + FAILED
        button(type="button", data-dev-add="pending", class="px-2 py-1 rounded bg-amber-600/80 text-amber-100 text-xs") + PENDING
    div(data-dev-force-cooling-wrap, class="hidden")
      button(type="button", data-dev-force-cooling-latest,
        class="w-full px-2 py-1.5 rounded bg-gray-200 text-[var(--text)] text-xs hover:bg-gray-300") Force cooling end (latest pending)
    div
      label(class="block text-[var(--muted)] mb-1") Force verify fail mode
      div(class="flex flex-wrap gap-1")
        each mode in ['NONE','FAIL','USED','AMOUNT']
          button(type="button", data-dev-verify-mode=mode,
            class="px-2 py-1 rounded text-xs bg-gray-200 text-[var(--muted)] hover:bg-gray-300")= mode
    div
      label(class="block text-[var(--muted)] mb-1") Force cooling end now
      button(type="button", data-dev-cooling-end-now,
        class="px-2 py-1 rounded text-xs bg-gray-200 text-[var(--muted)]") OFF
    div
      label(class="block text-[var(--muted)] mb-1") Auto-fill BRN
      div(class="flex flex-wrap gap-1")
        each p in [{label:'OK',value:'BRN1234567890'},{label:'NF',value:'BRN_NF_123'},{label:'USED',value:'BRN_USED_123'},{label:'AMT',value:'BRN_AMT_123'},{label:'FRAUD',value:'BRN_FRAUD_123'}]
          button(type="button", data-dev-ref=p.value,
            class="px-2 py-1 rounded bg-gray-200 text-[var(--text)] text-xs hover:bg-gray-300")= p.label
    div
      label(class="block text-[var(--muted)] mb-1") Auto-fill UTR
      div(class="flex flex-wrap gap-1")
        each p in [{label:'OK',value:'UTR1234567890'},{label:'NF',value:'UTR_NF_123'},{label:'USED',value:'UTR_USED_123'},{label:'AMT',value:'UTR_AMT_123'},{label:'FRAUD',value:'UTR_FRAUD_123'}]
          button(type="button", data-dev-ref=p.value,
            class="px-2 py-1 rounded bg-gray-200 text-[var(--text)] text-xs hover:bg-gray-300")= p.label
    div
      button(type="button", data-dev-reset-refs,
        class="w-full px-2 py-1.5 rounded bg-gray-200 text-[var(--text)] text-xs hover:bg-gray-300") Reset used references
    div
      button(type="button", data-dev-expire,
        class="w-full px-2 py-1.5 rounded bg-amber-600/80 text-amber-100 text-xs hover:bg-amber-600") Force session expired
    div
      button(type="button", data-dev-reset-history,
        class="w-full px-2 py-1.5 rounded bg-gray-200 text-[var(--text)] text-xs hover:bg-gray-300") Reset history to defaults
    div
      button(type="button", data-dev-reset,
        class="w-full px-2 py-1.5 rounded bg-red-600/80 text-red-100 text-xs hover:bg-red-600") Reset store
    p(class="text-[var(--muted)] text-xs hidden", data-dev-order) 
