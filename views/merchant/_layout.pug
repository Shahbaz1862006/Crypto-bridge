extends ../layout

block content
  div(class="flex min-h-screen bg-[var(--bg)]")
    aside(class="w-16 lg:w-56 flex flex-col bg-[var(--surface)] border-r border-[var(--border)] text-[var(--muted)]")
      div(class="p-4 border-b border-[var(--border)]")
        h1(
          role="button",
          tabindex="0",
          data-nav=ROUTES.MERCHANT.HOME,
          class="text-xl font-semibold text-gray-900 cursor-pointer hidden lg:inline"
        ) Merchant
      nav(class="flex-1 p-2")
        button(
          type="button",
          data-nav=ROUTES.MERCHANT.HISTORY,
          class=(active === 'history' ? 'w-full flex items-center gap-3 px-3 py-2 rounded-lg bg-[var(--green)]/15 text-[var(--green)] font-medium' : 'w-full flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-gray-100 text-[var(--muted)]')
        )
          span 📊
          span(class="hidden lg:inline") Transactions
    main(class="flex-1 flex flex-col min-w-0")
      block merchantContent
