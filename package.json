{
  "name": "crypto-bridge",
  "private": true,
  "version": "1.0.0",
  "description": "Fastpikeswop Crypto-Bridge (Pug + Express)",
  "scripts": {
    "dev": "concurrently -k -n css,server -c blue,green \"npm run css:watch\" \"npm run server:dev\"",
    "server:dev": "nodemon --watch server.js --watch views --ext js,pug server.js",
    "server": "node server.js",
    "css:watch": "tailwindcss -i ./src/styles/tailwind.css -o ./public/css/app.css --watch",
    "css:build": "tailwindcss -i ./src/styles/tailwind.css -o ./public/css/app.css --minify",
    "build": "npm run css:build",
    "start": "npm run build && npm run server"
  },
  "dependencies": {
    "express": "^4.21.2",
    "pug": "^3.0.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "tailwindcss": "^4.2.1",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9"
  }
}
